{
  "name": "discord-radio",
  "version": "1.0.0",
  "description": "A minimal, flexible audio stream player for Discord voice channels using FFmpeg. Supports play, stop, pause, resume, and volume control.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "discord",
    "discord.js",
    "voice",
    "audio",
    "player",
    "stream",
    "music",
    "radio",
    "bot",
    "ffmpeg",
    "typescript"
  ],
  "author": "motaz-darawsha",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/motaz-darawsha/discord-radio.git"
  },
  "bugs": {
    "url": "https://github.com/motaz-darawsha/discord-radio/issues"
  },
  "homepage": "https://github.com/motaz-darawsha/discord-radio#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "discord.js": ">=14.0.0"
  },
  "dependencies": {
    "@discordjs/voice": "^0.19.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "discord.js": "^14.25.1",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  }
}
